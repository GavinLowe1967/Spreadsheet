2. Add CellType type class.  Want to allow typing of
def cells[A <: CellType](cols: List[Column])(row: Row): List[A] =
  [Cell(c,r): A | c <- cols]
def sortBlockByColumn[A <: CellType](
    cols: List[Column], rows: List[Row], c: Column) = {
  def before(r1: Row, r2: Row) = Cell(c,r1): A <= Cell(c,r2)
  sortBlockBy(cols, rows, before)
}
operation sortByName() = sortBlockByColumn[String](columns, rows, #A)

