/** The factorial function. */
def fact(n: Int) : Int = { assert(n >= 0); if(n <= 1) 1 else n*fact(n-1) }

/** Overloaded sum functions. */
def sum(xs: List[Int]): Int = 
  if(isEmpty xs) 0 else head xs + sum(tail(xs))
def sum(xs: List[Float]): Float = 
  if(isEmpty xs) 0.0 else head xs + sum(tail(xs))
/** Apply function. */
def apply[A,B](f: A => B)(x: A) = f x
// Overloaded double function
def double(n: Int) = 2*n
def double(y: Float) = 2.0*y

// Row for the first empty cell in column c from row r.
def firstEmptyInCol(c: Column, r: Row): Row =
  Cell(c,r) match{ 
    case Empty => r; 
    case _: Int => firstEmptyInCol(c, r+1)
    case _ => firstEmptyInCol(c, r+1) 
  }

// =======================================================

/* Inputs are expected in column A. */

// Row 0
#A0 = 1/0: Int // Evaluation error
#B0 = 3; #B0 = 4.0 // Double-write  error
val hello = "Hello"; #C0 = hello
#D0 = apply(double: Float => Float) 3.0 : Float 
#E0 = double 2
#F0 = { assert(#E0: Int == 3); 5 }

/* Produce factorials, rows #1, #3 and #4 in columns #B and #C. */
for(r <- #1 to #4; c <- [#B, #C]; if r != #2){
  Cell(c, r) = fact(Cell(#A,r))
}

/** Produce factorials in rows row-end, excluding #2, column #D. */
def produceFacts(row: Row, end: Row): Boolean = {
  if(row == end) true
  else{
    // IMPROVE: use "if" statement
    val x = if(row != #2){ Cell(#D, row) = fact(Cell(#A,row)); 0 } else 1//0
    produceFacts(row+1, end)
  }
}

/* Produce factorials, rows #1, #3 and #4 in column #D. */
val bbb = produceFacts(#1, #4)

val firstEmpty = firstEmptyInCol(#A, #1) // Should give #4
Cell(#D, firstEmpty) = "first empty"

// Row 6
#A6 = fact(3); #B6 = 3+#A1 // untyped cell read.
#C6 = if(false) 3 else #A1 // Untyped cell read.
// List comprehension
#D6 = sum([Cell(c,#6):Int | c <- #A to #C]) // 17

// Rows 7, 8
// This test checks the inner declaration of flag doesn't leak. 
val flag = true
val six = 6
#E7 = #A1 match{ case six: Int => six+3 } // 7
for(r <- #7 to #8; if r == #6 || flag){ 
  // Cell(#B, r) = flag; val flag = false // Illegal forward reference.
  Cell(#B, r) = true; val flag = false 
}  
// Repeated variable in for loop.  Allowed but yuk!
for(r <- 2 to 2; r <- #5+r to #6+r) Cell(#C, r) = six

// Test of empty blocks.
for(x <- #0 until #10){ }


